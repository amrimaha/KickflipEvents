# ── Supabase (shared with Node.js service) ──────────────────────────────────
# PostgreSQL connection URL (Transaction Pooler, port 6543)
# Found in: Supabase → Settings → Database → Connection pooling → URI
DATABASE_URL=postgresql://postgres.YOURREF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Supabase project URL and service role key
# Found in: Supabase → Settings → API
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# JWKS endpoint for admin auth (Supabase JWT public keys)
SUPABASE_JWKS_URL=https://YOURREF.supabase.co/auth/v1/.well-known/jwks.json

# ── Embeddings ───────────────────────────────────────────────────────────────
# IMPORTANT: Must match Amrita's Voyage AI setup (1024 dims)
# Ravi's config defaults to Google Gemini embeddings — override to match the
# shared Supabase VECTOR(1024) column.
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=1024
# API key for embedding (Google AI Studio key, or use LLM_API_KEY as fallback)
LLM_API_KEY=your-google-ai-studio-key

# ── Crawler behaviour ────────────────────────────────────────────────────────
ENABLE_PLAYWRIGHT=true
MAX_CONCURRENT_SOURCES=3
RESPECT_ROBOTS_TXT=true
ENABLE_LLM_FALLBACK=false

# ── Cron auth (same value as Node.js CRON_SECRET) ───────────────────────────
CRON_SECRET=your-shared-cron-secret

# ── Playwright browser path (set automatically on Railway) ───────────────────
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
